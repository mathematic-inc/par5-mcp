{
  "name": "par5-mcp",
  "version": "0.2.4",
  "description": "MCP server for parallel list operations - run shell commands and AI agents across lists in parallel",
  "main": "dist/index.js",
  "packageManager": "pnpm@10.31.0+sha512.e3927388bfaa8078ceb79b748ffc1e8274e84d75163e67bc22e06c0d3aed43dd153151cbf11d7f8301ff4acb98c68bdc5cadf6989532801ffafe3b3e4a63c268",
  "bin": {
    "par5-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build",
    "prepare": "test -n \"$CI\" || lefthook install",
    "lint": "ultracite check",
    "format": "ultracite fix"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "parallel",
    "batch",
    "shell",
    "ai-agents",
    "claude",
    "gemini",
    "codex",
    "automation"
  ],
  "author": "Mathematic Inc",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/mathematic-inc/par5-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/mathematic-inc/par5-mcp/issues"
  },
  "homepage": "https://github.com/mathematic-inc/par5-mcp#readme",
  "engines": {
    "node": ">=24"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild",
      "lefthook"
    ]
  },
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/eff-diceware-passphrase": "^3.0.2",
    "eff-diceware-passphrase": "^3.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^25.4.0",
    "lefthook": "^2.1.3",
    "typescript": "^5.9.3",
    "ultracite": "^7.2.5"
  }
}
